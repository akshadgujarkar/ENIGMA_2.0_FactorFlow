FLASK_ENV=development
FLASK_DEBUG=true

# CORS origins for the React frontend (comma-separated or * for all)
CORS_ORIGINS=http://localhost:8080

# Google Earth Engine
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=/absolute/path/to/gee-private-key.json

# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-service-account.json
FIREBASE_DB_URL=https://your-project-id.firebaseio.com

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=3600

# Gemini / Google Generative AI
GEMINI_API_KEY=AIzaSyDopcnwcNbwSA2L5pfmod4vPklxTud6Vbo
GEMINI_MODEL_NAME=models/gemini-2.5-flash

# Model storage
MODELS_DIR=./models

