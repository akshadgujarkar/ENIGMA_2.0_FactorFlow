FLASK_ENV=development
FLASK_DEBUG=true

# CORS origins for the React frontend (comma-separated or * for all)
CORS_ORIGINS=http://localhost:8080

# Google Earth Engine
# Option 1 (recommended for free usage): run `earthengine authenticate` locally
# and leave these blank to use the free OAuth-based credentials.
GEE_SERVICE_ACCOUNT=
GEE_PRIVATE_KEY_PATH=

# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-service-account.json
FIREBASE_DB_URL=https://your-project-id.firebaseio.com

# Gemini / Google Generative AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_NAME=models/gemini-2.5-flash

# Model storage
MODELS_DIR=./models

