GEE_PROJECT=sdg11-488617
GEE_SERVICE_ACCOUNT=
GEE_PRIVATE_KEY_PATH=

# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=sdg11-fa9bc-firebase-adminsdk-fbsvc-6745bb91be.json
FIREBASE_DB_URL=https://sdg11-fa9bc-default-rtdb.firebaseio.com

# Gemini / Google Generative AI
GEMINI_API_KEY=AIzaSyDopcnwcNbwSA2L5pfmod4vPklxTud6Vbo
